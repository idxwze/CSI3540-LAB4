<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>CSI3540 Lab4</display-name>

    <session-config>
        <session-timeout>10</session-timeout>
    </session-config>

    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>ca.uottawa.csi3540.lab4.servlet.RegisterServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RegisterServlet</servlet-name>
        <url-pattern>/register</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>Exam1Servlet</servlet-name>
        <servlet-class>ca.uottawa.csi3540.lab4.servlet.Exam1Servlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>Exam1Servlet</servlet-name>
        <url-pattern>/exam1</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>Exam2Servlet</servlet-name>
        <servlet-class>ca.uottawa.csi3540.lab4.servlet.Exam2Servlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>Exam2Servlet</servlet-name>
        <url-pattern>/exam2</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ResultServlet</servlet-name>
        <servlet-class>ca.uottawa.csi3540.lab4.servlet.ResultServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ResultServlet</servlet-name>
        <url-pattern>/result</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>ca.uottawa.csi3540.lab4.servlet.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <welcome-file-list>
        <welcome-file>index.html</welcome-file>
    </welcome-file-list>
</web-app>
